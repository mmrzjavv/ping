@using Microsoft.AspNetCore.Identity
@using TwitterClone.Infrastructure.Identity;
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    string returnUrl = null;
    var query = ViewContext.HttpContext.Request.Query;
    if (query.ContainsKey("returnUrl"))
    {
        returnUrl = query["returnUrl"];
    }
}

<ul class="navbar-nav ms-auto align-items-center gap-3">
    <li class="nav-item">
        <a class="nav-link d-flex align-items-center gap-2 px-3 py-2 rounded-4 bg-white shadow-sm border border-1 border-light text-dark fw-semibold"
           asp-area=""
           asp-page="/Index">
            <img src="/logo.png" alt="Logo" style="width:32px;height:32px;object-fit:contain;" />
            <span>TwitterClone</span>
        </a>
    </li>

    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <a class="nav-link d-flex align-items-center gap-2 px-3 py-2 rounded-4 bg-light text-dark fw-semibold border"
               asp-area="Identity"
               asp-page="/Account/Manage/Index"
               title="Manage">
                <i class="bi bi-person-circle"></i>
                <span>Hello @User.Identity.Name!</span>
            </a>
        </li>

        <li class="nav-item">
            <form class="d-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/">
                <button type="submit"
                        class="btn btn-danger rounded-4 px-3 py-2 fw-semibold shadow-sm">
                    <i class="bi bi-box-arrow-right me-1"></i>
                    Logout
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="btn btn-outline-primary rounded-4 px-3 py-2 fw-semibold shadow-sm me-2"
               asp-area="Identity"
               asp-page="/Account/Register"
               asp-route-returnUrl="@returnUrl">
                Register
            </a>
        </li>
        <li class="nav-item">
            <a class="btn btn-primary rounded-4 px-3 py-2 fw-semibold shadow-sm"
               asp-area="Identity"
               asp-page="/Account/Login"
               asp-route-returnUrl="@returnUrl">
                Login
            </a>
        </li>
    }
</ul>
